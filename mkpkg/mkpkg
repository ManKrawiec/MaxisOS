#!/usr/bin/env bash
set -euo pipefail

ROOT="/"
DB_ROOT="/var/lib/mkpkg"
REPO_CONF="/etc/mkpkg/repos.conf"
CACHE="/var/cache/mkpkg"

usage() {
  cat <<'EOM'
Usage: mkpkg [--root <path>] <command> [args]

Commands:
  install <pkg|path.mkpkg>
  remove <pkg>
  update
  verify
  search <term>
  list
EOM
}

require_root() {
  if [[ "$(id -u)" -ne 0 ]]; then
    echo "mkpkg must be run as root"
    exit 1
  fi
}

repos() {
  if [[ ! -f "$ROOT$REPO_CONF" ]]; then
    echo "Repo config missing: $ROOT$REPO_CONF"
    exit 1
  fi
  grep -vE '^\s*#' "$ROOT$REPO_CONF" | awk 'NF'
}

find_pkg_in_repos() {
  local name="$1"
  local repo
  while read -r repo; do
    if [[ -f "$repo/${name}.mkpkg" ]]; then
      echo "$repo/${name}.mkpkg"
      return 0
    fi
  done < <(repos)
  return 1
}

install_pkg() {
  local target="$1"
  local pkgfile

  if [[ -f "$target" ]]; then
    pkgfile="$target"
  else
    pkgfile="$(find_pkg_in_repos "$target" || true)"
  fi

  if [[ -z "$pkgfile" ]]; then
    echo "Package not found: $target"
    exit 1
  fi

  mkdir -p "$ROOT$CACHE" "$ROOT$DB_ROOT/installed"

  local tmp
  tmp="$(mktemp -d)"
  tar -xf "$pkgfile" -C "$tmp"

  if [[ ! -f "$tmp/metadata.json" ]]; then
    echo "Invalid package: missing metadata.json"
    rm -rf "$tmp"
    exit 1
  fi

  local name
  name="$(grep -oE '\"name\"\\s*:\\s*\"[^\"]+\"' \"$tmp/metadata.json\" | head -1 | sed -E 's/.*\"name\"\\s*:\\s*\"([^\"]+)\".*/\\1/')"

  echo "Installing $name"
  mkdir -p "$ROOT$DB_ROOT/installed/$name"
  cp "$tmp/metadata.json" "$ROOT$DB_ROOT/installed/$name/metadata.json"

  if [[ -d "$tmp/files" ]]; then
    (cd "$tmp/files" && find . -type f -o -type l) > "$ROOT$DB_ROOT/installed/$name/files.lst"
    (cd "$tmp/files" && tar -cf - .) | (cd "$ROOT" && tar -xpf -)
  else
    echo "No files/ directory in package"
  fi

  if [[ -f "$tmp/install.sh" ]]; then
    cp "$tmp/install.sh" "$ROOT$DB_ROOT/installed/$name/install.sh"
    bash "$tmp/install.sh" "install" "$ROOT"
  fi

  rm -rf "$tmp"
}

remove_pkg() {
  local name="$1"
  local meta="$ROOT$DB_ROOT/installed/$name/metadata.json"
  local files="$ROOT$DB_ROOT/installed/$name/files.lst"

  if [[ ! -f "$meta" ]]; then
    echo "Not installed: $name"
    exit 1
  fi

  if [[ -f "$files" ]]; then
    while read -r f; do
      rm -f "$ROOT/${f#./}"
    done < "$files"
  fi

  if [[ -f "$ROOT$DB_ROOT/installed/$name/install.sh" ]]; then
    bash "$ROOT$DB_ROOT/installed/$name/install.sh" "remove" "$ROOT"
  fi

  rm -rf "$ROOT$DB_ROOT/installed/$name"
  echo "Removed $name"
}

update_db() {
  mkdir -p "$ROOT$CACHE"
  verify_repos
  echo "Repositories in $ROOT$REPO_CONF are treated as local filesystem repos."
  echo "To update, synchronize your /repo trees with your build outputs."
}

verify_repos() {
  local errors=0
  local repo
  while read -r repo; do
    [[ -d "$repo" ]] || continue
    local pkg
    for pkg in "$repo"/*.mkpkg; do
      [[ -f "$pkg" ]] || continue
      if ! tar -tf "$pkg" | grep -q '^metadata.json$'; then
        echo "Invalid package (missing metadata.json): $pkg"
        errors=$((errors+1))
        continue
      fi
      if ! tar -tf "$pkg" | grep -q '^files/'; then
        echo "Invalid package (missing files/): $pkg"
        errors=$((errors+1))
        continue
      fi
      local name
      name="$(tar -xOf "$pkg" metadata.json 2>/dev/null | grep -oE '\"name\"\\s*:\\s*\"[^\"]+\"' | head -1 | sed -E 's/.*\"name\"\\s*:\\s*\"([^\"]+)\".*/\\1/')"
      if [[ -z "$name" ]]; then
        echo "Invalid package (metadata name missing): $pkg"
        errors=$((errors+1))
      fi
    done
  done < <(repos)

  if [[ "$errors" -gt 0 ]]; then
    echo "mkpkg verify failed with $errors error(s)"
    exit 1
  fi
}

search_pkgs() {
  local term="$1"
  local repo
  while read -r repo; do
    ls "$repo"/*.mkpkg 2>/dev/null | sed 's#.*/##; s/\.mkpkg$//' | grep -i "$term" || true
  done < <(repos)
}

list_installed() {
  ls "$ROOT$DB_ROOT/installed" 2>/dev/null || true
}

while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --root)
      ROOT="${2:-}"
      shift 2
      ;;
    --root=*)
      ROOT="${1#*=}"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      usage
      exit 1
      ;;
  esac
done

ROOT="${ROOT%/}"
if [[ -z "$ROOT" ]]; then
  ROOT="/"
fi
DB_ROOT="/var/lib/mkpkg"
REPO_CONF="/etc/mkpkg/repos.conf"
CACHE="/var/cache/mkpkg"

cmd="${1:-}"
case "$cmd" in
  install)
    require_root
    install_pkg "${2:-}"
    ;;
  remove)
    require_root
    remove_pkg "${2:-}"
    ;;
  update)
    update_db
    ;;
  verify)
    verify_repos
    ;;
  search)
    search_pkgs "${2:-}"
    ;;
  list)
    list_installed
    ;;
  *)
    usage
    exit 1
    ;;
esac

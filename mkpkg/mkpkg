#!/usr/bin/env bash
set -euo pipefail

DB_ROOT="/var/lib/mkpkg"
REPO_CONF="/etc/mkpkg/repos.conf"
CACHE="/var/cache/mkpkg"

usage() {
  cat <<'EOM'
Usage: mkpkg <command> [args]

Commands:
  install <pkg|path.mkpkg>
  remove <pkg>
  update
  search <term>
  list
EOM
}

require_root() {
  if [[ "$(id -u)" -ne 0 ]]; then
    echo "mkpkg must be run as root"
    exit 1
  fi
}

repos() {
  if [[ ! -f "$REPO_CONF" ]]; then
    echo "Repo config missing: $REPO_CONF"
    exit 1
  fi
  grep -vE '^\s*#' "$REPO_CONF" | awk 'NF'
}

find_pkg_in_repos() {
  local name="$1"
  local repo
  while read -r repo; do
    if [[ -f "$repo/${name}.mkpkg" ]]; then
      echo "$repo/${name}.mkpkg"
      return 0
    fi
  done < <(repos)
  return 1
}

install_pkg() {
  local target="$1"
  local pkgfile

  if [[ -f "$target" ]]; then
    pkgfile="$target"
  else
    pkgfile="$(find_pkg_in_repos "$target" || true)"
  fi

  if [[ -z "$pkgfile" ]]; then
    echo "Package not found: $target"
    exit 1
  fi

  mkdir -p "$CACHE" "$DB_ROOT/installed"

  local tmp
  tmp="$(mktemp -d)"
  tar -xf "$pkgfile" -C "$tmp"

  if [[ ! -f "$tmp/metadata.json" ]]; then
    echo "Invalid package: missing metadata.json"
    rm -rf "$tmp"
    exit 1
  fi

  local name
  name="$(grep -oE '\"name\"\\s*:\\s*\"[^\"]+\"' \"$tmp/metadata.json\" | head -1 | sed -E 's/.*\"name\"\\s*:\\s*\"([^\"]+)\".*/\\1/')"

  echo "Installing $name"
  mkdir -p "$DB_ROOT/installed/$name"
  cp "$tmp/metadata.json" "$DB_ROOT/installed/$name/metadata.json"

  if [[ -d "$tmp/files" ]]; then
    (cd "$tmp/files" && find . -type f -o -type l) > "$DB_ROOT/installed/$name/files.lst"
    (cd "$tmp/files" && tar -cf - .) | (cd / && tar -xpf -)
  else
    echo "No files/ directory in package"
  fi

  if [[ -f "$tmp/install.sh" ]]; then
    cp "$tmp/install.sh" "$DB_ROOT/installed/$name/install.sh"
    bash "$tmp/install.sh" "install" "/"
  fi

  rm -rf "$tmp"
}

remove_pkg() {
  local name="$1"
  local meta="$DB_ROOT/installed/$name/metadata.json"
  local files="$DB_ROOT/installed/$name/files.lst"

  if [[ ! -f "$meta" ]]; then
    echo "Not installed: $name"
    exit 1
  fi

  if [[ -f "$files" ]]; then
    while read -r f; do
      rm -f "/${f#./}"
    done < "$files"
  fi

  if [[ -f "$DB_ROOT/installed/$name/install.sh" ]]; then
    bash "$DB_ROOT/installed/$name/install.sh" "remove" "/"
  fi

  rm -rf "$DB_ROOT/installed/$name"
  echo "Removed $name"
}

update_db() {
  mkdir -p "$CACHE"
  echo "Repositories in $REPO_CONF are treated as local filesystem repos."
  echo "To update, synchronize your /repo trees with your build outputs."
}

search_pkgs() {
  local term="$1"
  local repo
  while read -r repo; do
    ls "$repo"/*.mkpkg 2>/dev/null | sed 's#.*/##; s/\.mkpkg$//' | grep -i "$term" || true
  done < <(repos)
}

list_installed() {
  ls "$DB_ROOT/installed" 2>/dev/null || true
}

cmd="${1:-}"
case "$cmd" in
  install)
    require_root
    install_pkg "${2:-}"
    ;;
  remove)
    require_root
    remove_pkg "${2:-}"
    ;;
  update)
    update_db
    ;;
  search)
    search_pkgs "${2:-}"
    ;;
  list)
    list_installed
    ;;
  *)
    usage
    exit 1
    ;;
esac
